[run]
source =
    bootstrap.py
    config.py
    main.py
    core
    dashboard
    scenarios
    services
omit =
    legacy/*
    tests/*
    */__pycache__/*

[report]
show_missing = True
skip_covered = True
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
