# Android Game CV Autopilot environment template
# Шаблон переменных окружения Android Game CV Autopilot
#
# Copy to .env for local Docker runs. Never commit real .env files.
# Скопируй в .env для локального Docker. Реальный .env не коммить.

DASHBOARD_AUTH_ENABLED=1
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
DASHBOARD_MCP_API_KEY=change-me

# Vision/CV provider key. Keep empty until needed.
# Ключ Vision/CV провайдера. Оставь пустым, пока не нужен.
OPENROUTER_API_KEY=
CV_MODELS=anthropic/claude-sonnet-4-6,openai/gpt-4o

# Device selection.
# Выбор устройства.
DEVICE_FARM=local
LOCAL_DEVICE=auto
ADB_SERVER_SOCKET=tcp:host.docker.internal:5037

# Remote farms. Fill only when used.
# Удаленные фермы. Заполняй только при использовании.
GENYMOTION_API_TOKEN=
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
LT_USERNAME=
LT_ACCESS_KEY=

# Safety defaults. Dashboard/Docker keep real purchases blocked.
# Безопасные значения. Dashboard/Docker блокируют реальные покупки.
PURCHASE_MODE=preview
GOOGLE_PHONE_MODE=manual
